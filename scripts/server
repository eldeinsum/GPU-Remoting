#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
profile="debug"
cargo_args=()

if [[ "${1:-}" == "--release" ]]; then
    profile="release"
    cargo_args+=(--release)
    shift
fi

if [[ -z "${NETWORK_CONFIG:-}" ]]; then
    if [[ -f "$repo_root/config.toml" ]]; then
        export NETWORK_CONFIG="$repo_root/config.toml"
    elif [[ -f "$repo_root/config.example.toml" ]]; then
        export NETWORK_CONFIG="$repo_root/config.example.toml"
    else
        echo "network config not found. Set NETWORK_CONFIG." >&2
        exit 2
    fi
fi

gpucr_home="${GPUCR_HOME:-"$repo_root/../GPU-CR"}"
runtime="${GPUCR_RUNTIME:-"$gpucr_home/build-nvidia/gpucr-nvidia.so"}"
if [[ ! -f "$runtime" ]]; then
    runtime="$gpucr_home/rust/target/release/libgpucr_preload.so"
fi
if [[ ! -f "$runtime" ]]; then
    echo "GPU-CR runtime not found. Set GPUCR_HOME or GPUCR_RUNTIME." >&2
    exit 2
fi

export CARGO_INCREMENTAL=0
cargo build "${cargo_args[@]}" --bin server
bin="$repo_root/target/$profile/server"

export LD_PRELOAD="$runtime${LD_PRELOAD:+:$LD_PRELOAD}"
exec "$bin" "$@"
